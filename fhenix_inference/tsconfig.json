{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "types": ["node", "hardhat"],
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["./hardhat.config.ts", "./scripts", "./test", "./typechain-types"],
  "files": []
}
