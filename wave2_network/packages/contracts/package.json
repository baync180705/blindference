{
  "name": "@blindference/contracts",
  "version": "0.1.0",
  "private": true,
  "license": "BUSL-1.1",
  "description": "Blindference protocol contracts (Solidity)",
  "scripts": {
    "build": "forge build",
    "test": "forge test -vv",
    "test:gas": "forge test --gas-report",
    "test:ci": "FOUNDRY_PROFILE=ci forge test",
    "format": "forge fmt && prettier --write \"contracts/**/*.sol\" \"test/**/*.sol\"",
    "format:check": "forge fmt --check && prettier --check \"contracts/**/*.sol\" \"test/**/*.sol\"",
    "lint": "solhint \"contracts/**/*.sol\" \"test/**/*.sol\"",
    "lint:fix": "solhint --fix \"contracts/**/*.sol\" \"test/**/*.sol\"",
    "clean": "forge clean"
  },
  "dependencies": {
    "@openzeppelin/contracts": "~5.2.0",
    "@openzeppelin/contracts-upgradeable": "~5.2.0",
    "@fhenixprotocol/cofhe-contracts": "0.0.13",
    "@fhenixprotocol/cofhe-mock-contracts": "^0.3.1"
  },
  "devDependencies": {
    "forge-std": "github:foundry-rs/forge-std",
    "prettier": "^3.2.0",
    "prettier-plugin-solidity": "^1.3.0",
    "solhint": "^5.0.0"
  }
}
